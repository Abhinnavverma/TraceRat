# ======================
# TraceRat Configuration
# ======================

# --- GitHub App ---
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY_PATH=/app/secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PR_EVENTS_TOPIC=pr-events
KAFKA_CONSUMER_GROUP=tracerat

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=tracerat
POSTGRES_PASSWORD=tracerat_dev
POSTGRES_DB=tracerat

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tracerat_dev

# --- Service Ports ---
API_GATEWAY_PORT=8000

# --- LLM (pluggable) ---
LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-4

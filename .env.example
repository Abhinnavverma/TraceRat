# ============================================================
# TraceRat – Environment Variables
# ============================================================
# Copy this file to .env and fill in the values marked REQUIRED.
# Variables with defaults (shown after :-) are optional.
# ============================================================

# ---------------------------------------------------------
# GitHub App  (REQUIRED for live webhook mode)
# ---------------------------------------------------------
# Create a free GitHub App at https://github.com/settings/apps
# Download the PEM key and place it in ./secrets/github-app.pem
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------
# LLM  (REQUIRED – free Gemini key works)
# ---------------------------------------------------------
# Get a free API key at https://aistudio.google.com/app/apikey
LLM_API_KEY=

# ---------------------------------------------------------
# Embedding  (optional – defaults to local model)
# ---------------------------------------------------------
# sentence-transformer (free, local) | openai (requires key)
EMBEDDING_BACKEND=sentence-transformer
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
# Only needed when EMBEDDING_BACKEND=openai
OPENAI_API_KEY=

# ---------------------------------------------------------
# Prediction Weights  (optional – sensible defaults)
# ---------------------------------------------------------
PREDICTION_CHANGE_SIZE_WEIGHT=0.30
PREDICTION_DEPTH_WEIGHT=0.25
PREDICTION_TRAFFIC_WEIGHT=0.25
PREDICTION_HISTORY_WEIGHT=0.20
PREDICTION_BUFFER_TTL_SECONDS=60
PREDICTION_SWEEP_INTERVAL_SECONDS=10
